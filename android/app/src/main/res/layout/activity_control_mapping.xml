<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MX SpatialBridge"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#0070D2"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AR input controller for MX Creative Console"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_marginBottom="24dp" />

        <!-- Connection Status -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="STATUS"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#0070D2"
            android:letterSpacing="0.15"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:background="#252540"
            android:textColor="#CCCCCC"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="20dp"
            android:contentDescription="@string/content_description_connection_status" />

        <!-- IP / Port -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CONNECT FROM OPTIONS+"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#0070D2"
            android:letterSpacing="0.15"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_ip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:background="#252540"
            android:textColor="#00FF88"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="20dp"
            android:contentDescription="@string/content_description_ip_port" />

        <!-- Active Profile -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ACTIVE PROFILE &amp; MAPPINGS"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#0070D2"
            android:letterSpacing="0.15"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_profile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:background="#252540"
            android:textColor="#CCCCCC"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="20dp"
            android:contentDescription="@string/content_description_active_profile" />

        <!-- Control button -->
        <Button
            android:id="@+id/btn_start_stop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start Sync Server"
            android:backgroundTint="#0070D2"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:contentDescription="@string/content_description_start_stop" />

    </LinearLayout>
</ScrollView>

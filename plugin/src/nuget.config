<?xml version="1.0" encoding="utf-8"?>
<!--
  NuGet configuration for MX SpatialBridge plugin.

  The Logi Actions SDK (Loupedeck.PluginSdk) is served from a local feed that
  the LogiPluginTool configures when you run:

      dotnet tool install --global LogiPluginTool
      logiplugintool configure-nuget

  That command adds the "Logi" source below automatically.
  The entry is included here so CI pipelines know which feed to expect.
-->
<configuration>
  <packageSources>
    <clear />
    <!-- Official NuGet for all other packages -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!--
      Logi Actions SDK feed — configured automatically by LogiPluginTool.
      Path matches the default Windows installation of Logi Plugin Service.
    -->
    <add key="Logi"
         value="%LOCALAPPDATA%\Logi\LogiPluginService\sdk\nuget\"
         protocolVersion="3" />
  </packageSources>
</configuration>
